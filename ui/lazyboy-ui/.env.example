# Browser shell configuration for the Vite dev/build. The shell reads
# these to pick and configure the RpcClient (src/shell/select.ts). The
# Tauri desktop shell ignores them: it injects TauriRpcClient when a Tauri
# runtime is present.

# Base URL of a running lazyboy-server (matches LAZYBOY_ADDR; default
# http://localhost:7878). The browser shell talks HTTP+SSE to it.
VITE_CORE_URL=http://localhost:7878

# Single-tenant bearer (matches the server's LAZYBOY_TOKEN). Leave empty
# when the server runs with auth disabled (no LAZYBOY_TOKEN set).
VITE_CORE_TOKEN=

# Set to 1 to run against the in-memory fixture instead of a real server,
# for UI work with no backend. Never set in a real deployment.
# VITE_USE_MOCK=1
